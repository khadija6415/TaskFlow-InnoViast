<svg viewBox="0 0 1000 520" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <marker id="arrow" markerWidth="10" markerHeight="10" refX="8" refY="3" orient="auto" markerUnits="strokeWidth">
      <path d="M0,0 L0,6 L9,3 z" fill="#94A3B8" />
    </marker>
  </defs>

  <rect width="1000" height="520" fill="#F8FAFC" />

  <text x="500" y="45" text-anchor="middle" font-family="Arial, sans-serif" font-size="26" font-weight="bold" fill="#1E293B">TaskFlow — Task Workflow Diagram</text>
  <text x="500" y="72" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" fill="#64748B">How a task moves through the system, from creation to completion</text>

  <!-- Actors -->
  <rect x="40" y="110" width="160" height="60" rx="14" fill="#EDE9FE" stroke="#7C3AED" stroke-width="1.5"/>
  <text x="120" y="135" text-anchor="middle" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#5B21B6">Admin</text>
  <text x="120" y="153" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#6D28D9">Creates &amp; assigns task</text>

  <!-- Arrow actor -> todo -->
  <line x1="200" y1="140" x2="260" y2="140" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrow)"/>

  <!-- Column headers row -->
  <g font-family="Arial, sans-serif">
    <!-- To Do -->
    <rect x="260" y="110" width="170" height="60" rx="14" fill="#FFFFFF" stroke="#94A3B8" stroke-width="1.5"/>
    <circle cx="282" cy="140" r="6" fill="#94A3B8"/>
    <text x="345" y="135" text-anchor="middle" font-size="14" font-weight="bold" fill="#334155">To Do</text>
    <text x="345" y="153" text-anchor="middle" font-size="10" fill="#64748B">Task created, unassigned work</text>

    <!-- In Progress -->
    <rect x="470" y="110" width="170" height="60" rx="14" fill="#FFFFFF" stroke="#3B82F6" stroke-width="1.5"/>
    <circle cx="492" cy="140" r="6" fill="#3B82F6"/>
    <text x="555" y="135" text-anchor="middle" font-size="14" font-weight="bold" fill="#1D4ED8">In Progress</text>
    <text x="555" y="153" text-anchor="middle" font-size="10" fill="#64748B">Member is actively working</text>

    <!-- Review -->
    <rect x="680" y="110" width="150" height="60" rx="14" fill="#FFFFFF" stroke="#F59E0B" stroke-width="1.5"/>
    <circle cx="700" cy="140" r="6" fill="#F59E0B"/>
    <text x="755" y="135" text-anchor="middle" font-size="14" font-weight="bold" fill="#B45309">Review</text>
    <text x="755" y="153" text-anchor="middle" font-size="10" fill="#64748B">Awaiting feedback/approval</text>

    <!-- Done -->
    <rect x="870" y="110" width="90" height="60" rx="14" fill="#ECFDF5" stroke="#10B981" stroke-width="1.5"/>
    <circle cx="892" cy="140" r="6" fill="#10B981"/>
    <text x="915" y="135" text-anchor="middle" font-size="14" font-weight="bold" fill="#047857">Done</text>
    <text x="915" y="153" text-anchor="middle" font-size="9" fill="#64748B">Completed</text>
  </g>

  <!-- Arrows between columns -->
  <line x1="430" y1="140" x2="470" y2="140" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrow)"/>
  <line x1="640" y1="140" x2="680" y2="140" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrow)"/>
  <line x1="830" y1="140" x2="870" y2="140" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrow)"/>

  <!-- Feedback loop: Review -> In Progress (needs changes) -->
  <path d="M 755 170 C 755 210, 555 210, 555 170" fill="none" stroke="#F59E0B" stroke-width="1.8" stroke-dasharray="5,4" marker-end="url(#arrow)"/>
  <text x="655" y="205" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#B45309">Changes requested</text>

  <!-- Drag and drop note -->
  <rect x="260" y="240" width="700" height="46" rx="10" fill="#F1F5F9"/>
  <text x="610" y="268" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="#475569">Tasks move between columns via drag-and-drop on the Kanban board — status updates instantly in the database</text>

  <!-- Bottom section: parallel activities -->
  <text x="500" y="325" text-anchor="middle" font-family="Arial, sans-serif" font-size="15" font-weight="bold" fill="#1E293B">Throughout the Task Lifecycle</text>

  <g font-family="Arial, sans-serif">
    <!-- Comments -->
    <rect x="60" y="350" width="200" height="90" rx="14" fill="#FFFFFF" stroke="#CBD5E1" stroke-width="1.5"/>
    <text x="160" y="380" text-anchor="middle" font-size="13" font-weight="bold" fill="#334155">💬 Comments</text>
    <text x="160" y="400" text-anchor="middle" font-size="10" fill="#64748B">Team members discuss</text>
    <text x="160" y="415" text-anchor="middle" font-size="10" fill="#64748B">progress and blockers</text>

    <!-- Assignment -->
    <rect x="300" y="350" width="200" height="90" rx="14" fill="#FFFFFF" stroke="#CBD5E1" stroke-width="1.5"/>
    <text x="400" y="380" text-anchor="middle" font-size="13" font-weight="bold" fill="#334155">👥 Assignment</text>
    <text x="400" y="400" text-anchor="middle" font-size="10" fill="#64748B">One or more members</text>
    <text x="400" y="415" text-anchor="middle" font-size="10" fill="#64748B">assigned to a task</text>

    <!-- Priority & Deadline -->
    <rect x="540" y="350" width="200" height="90" rx="14" fill="#FFFFFF" stroke="#CBD5E1" stroke-width="1.5"/>
    <text x="640" y="380" text-anchor="middle" font-size="13" font-weight="bold" fill="#334155">⏰ Priority &amp; Deadline</text>
    <text x="640" y="400" text-anchor="middle" font-size="10" fill="#64748B">High/Medium/Low priority</text>
    <text x="640" y="415" text-anchor="middle" font-size="10" fill="#64748B">with due dates tracked</text>

    <!-- Dashboard -->
    <rect x="780" y="350" width="180" height="90" rx="14" fill="#FFFFFF" stroke="#CBD5E1" stroke-width="1.5"/>
    <text x="870" y="380" text-anchor="middle" font-size="13" font-weight="bold" fill="#334155">📊 Dashboard</text>
    <text x="870" y="400" text-anchor="middle" font-size="10" fill="#64748B">Stats &amp; charts update</text>
    <text x="870" y="415" text-anchor="middle" font-size="10" fill="#64748B">in real time</text>
  </g>

  <!-- Connector lines from lifecycle box up -->
  <line x1="160" y1="350" x2="160" y2="300" stroke="#CBD5E1" stroke-width="1.5"/>
  <line x1="400" y1="350" x2="400" y2="300" stroke="#CBD5E1" stroke-width="1.5"/>
  <line x1="640" y1="350" x2="640" y2="300" stroke="#CBD5E1" stroke-width="1.5"/>
  <line x1="870" y1="350" x2="870" y2="300" stroke="#CBD5E1" stroke-width="1.5"/>
  <line x1="160" y1="300" x2="870" y2="300" stroke="#CBD5E1" stroke-width="1.5"/>

  <text x="500" y="490" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#94A3B8">TaskFlow-InnoViast | Full-Stack Product Engineering | Week 2</text>
</svg>
